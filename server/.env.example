# ---- Server ----
PORT=5000
NODE_ENV=development

# ---- Database ----
# Local: mongodb://127.0.0.1:27017/evently
# Atlas: mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/evently?retryWrites=true&w=majority
MONGO_URI=mongodb://127.0.0.1:27017/evently

# ---- Auth ----
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_this_with_a_long_random_string
JWT_EXPIRES_IN=7d

# ---- CORS ----
# Comma-separated list of allowed origins (no trailing slashes)
CLIENT_ORIGIN=http://localhost:5173

# ---- Admin bootstrap (used by seed script) ----
ADMIN_EMAIL=admin@evently.dev
ADMIN_PASSWORD=ChangeMe#2026
ADMIN_NAME=Platform Admin

# ---- Rate limiting ----
AUTH_RATE_LIMIT_MAX=5
AUTH_RATE_LIMIT_WINDOW_MS=900000
